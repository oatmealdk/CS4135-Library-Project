# Database
# Each service uses its own logical database via a separate JDBC URL.
# In Docker Compose the hostnames are the container names (e.g. postgres)
USER_DB_URL=jdbc:postgresql://localhost:5432/elibrary_users
BORROWING_DB_URL=jdbc:postgresql://localhost:5432/elibrary_borrowing
BOOK_DB_URL=jdbc:postgresql://localhost:5432/elibrary_books
NOTIFICATION_DB_URL=jdbc:postgresql://localhost:5432/elibrary_notifications

DB_USERNAME=postgres
DB_PASSWORD=changeme

# JWT
# HS256 requires a key of at least 256 bits (32 bytes).
# Generate a suitable secret with:
#   openssl rand -base64 48
# or on PowerShell:
#   [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Max 256 }) -as [byte[]])
JWT_SECRET=REPLACE_ME_WITH_A_BASE64_SECRET_AT_LEAST_32_BYTES

# RabbitMQ
# Defaults to guest/guest when omitted in docker-compose.yml.
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
